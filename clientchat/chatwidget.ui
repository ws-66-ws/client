           <widget class="QWidget" name="contactInfoPage">
            <property name="styleSheet">
             <string notr="true">/* 头像 - 设置为圆形 */
QLabel#icon_Label {
    min-width: 90px;
    min-height: 90px;
    border-radius: 45px;
    background-color: #555;
}

/* 昵称 - 大字加粗白色 */
QLabel#nick_Label {
    color: #FFFFFF;
    font-size: 20px;
    font-weight: bold;
}

/* QQ号/邮箱 - 浅灰色 */
QLabel#email_Label {
    color: #999999;
    font-size: 12px;
    margin-top: 4px;
}

/* 性别/年龄/星座 - 带上边距 */
QLabel#sex_Label {
    color: #CCCCCC;
    font-size: 12px;
    margin-top: 10px;
}

/* 签名标签（&quot;签名&quot;两个字） */
QLabel#qianming_Label {
    color: #999999;
    font-size: 12px;
}

/* 签名的内容 - 亮白色 */
QLabel#desc_Label {
    color: #EEEEEE;
    font-size: 14px;
}

/* 编辑资料按钮 - 边框透明 */
QPushButton#bianji_Btn {
    background-color: transparent;
    border: 1px solid #555555;
    border-radius: 4px;
    color: #CCCCCC;
    padding: 6px 20px;
    font-size: 12px;
}
QPushButton#bianji_Btn:hover {
    background-color: #3a3a3a;
}

/* 发送消息按钮 - 蓝色实心 */
QPushButton#sendMsg_Btn {
    background-color: #1976d2;
    color: white;
    border: none;
    border-radius: 4px;
    padding: 6px 20px;
    font-size: 12px;
}
QPushButton#sendMsg_Btn:hover {
    background-color: #1565c0;
}</string>
