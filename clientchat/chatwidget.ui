             <item>
              <widget class="QListWidget" name="chatUser_List">
               <property name="styleSheet">
                <string notr="true">QListWidget { background-color: transparent; border: none; outline: none; } 
QListWidget::item { margin-top: 2px; margin-bottom: 2px;} 
QListWidget::item:selected { background-color: #333; } 
QListWidget::item:hover { background-color:#2e2e2e; }
/* 垂直滚动条整体样式 */
QListWidget QScrollBar:vertical {
    border: none;              /* 去掉边框 */
    background: transparent;   /* 背景透明 */
    width: 8px;                /* 滚动条宽度（细一些） */
    margin: 0px 0px 0px 0px;   /* 与边缘的距离 */
}

/* 滚动条滑块（拖动的那个条） */
QListWidget QScrollBar::handle:vertical {
    background: rgba(100, 100, 100, 150); /* 深灰半透明 */
    min-height: 30px;           /* 滑块最小高度 */
    border-radius: 4px;         /* 圆角 */
}

/* 鼠标悬浮在滑块上时变亮 */
QListWidget QScrollBar::handle:vertical:hover {
    background: rgba(120, 120, 120, 200);
}

/* 隐藏上下两端的箭头按钮 */
QListWidget QScrollBar::add-line:vertical {
    height: 0px;
    subcontrol-position: bottom;
    subcontrol-origin: margin;
}
QListWidget QScrollBar::sub-line:vertical {
    height: 0px;
    subcontrol-position: top;
    subcontrol-origin: margin;
}

/* 隐藏滑块上下方的灰色背景（保持纯净，不显示） */
QListWidget QScrollBar::add-page:vertical, QListWidget QScrollBar::sub-page:vertical {
    background: none;
}</string>
