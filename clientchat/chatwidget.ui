                     <font>
                      <bold>true</bold>
                     </font>
                    </property>
                    <property name="styleSheet">
                     <string notr="true">/* 普通状态 */
QPushButton {
    background-color: #1976d2;
    color: white;
    border: none;
    border-radius: 10px;
    font-weight: bold;
}

/* 鼠标悬停状态 */
QPushButton:hover {
    background-color: #1565c0;
}

/* 鼠标按下状态 */
QPushButton:pressed {
    background-color: #0d47a1;
}

/* 【新增】不可用状态 */
QPushButton:disabled {
    color: #888888;               /* 文本变淡为浅灰色 */
}</string>
                    </property>
